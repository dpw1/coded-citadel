{
  "name": "coded-citadel",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "prebuild": "npm run import-blog-screenshots && npm run generate-blog-manifest && npm run generate-portfolio-analytics",
    "import-blog-screenshots": "node back-end/import-blog-screenshots.mjs",
    "build": "npm run maybe-extract-chrome-apps && npm run compute-portfolio-stats && npm run fetch-youtube && npm run generate-sitemap && vite build",
    "generate-portfolio-analytics": "node back-end/generate-portfolio-analytics.mjs",
    "generate-blog-manifest": "node back-end/generate-blog-manifest.mjs",
    "compute-portfolio-stats": "node back-end/compute-portfolio-stats.mjs",
    "maybe-extract-chrome-apps": "node back-end/maybe-extract-chrome-apps.mjs",
    "preview": "vite preview",
    "fetch-youtube": "npm install --prefix back-end && node back-end/fetch-youtube-videos.mjs",
    "extract-chrome-apps": "node back-end/extract-chrome-apps.mjs",
    "generate-sitemap": "node back-end/generate-sitemap.mjs",
    "resize-favicon": "node back-end/resize-favicon.mjs"
  },
  "dependencies": {
    "chart.js": "^4.5.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^7.15.1"
  },
  "devDependencies": {
    "@prerenderer/renderer-puppeteer": "^1.2.4",
    "@prerenderer/rollup-plugin": "^0.3.12",
    "@types/react": "^18.3.1",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.1",
    "puppeteer": "^25.0.4",
    "sharp": "^0.34.2",
    "vite": "^5.4.1",
    "gray-matter": "^4.0.3",
    "marked": "^15.0.7"
  }
}
